# =============================================================================
# WebPDF_V12 — Git 忽略（不上传浏览器二进制、虚拟环境、密钥与运行数据）
# =============================================================================

# 浏览器内核与缓存（体积大，各机器自行 playwright install / camoufox 下载）
browser_cores/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.python-version
.ruff_cache/
.mypy_cache/
.pytest_cache/
*.egg-info/
dist/
build/
wheels/

# 环境变量与本地密钥（勿提交真实配置）
.env
.env.*
!.env.example
crawlee_secret_config.py

# Crawlee / 运行时数据
storage/
.crawlee/

# 日志与下载产物
logs/
*.log
*.log.*
downloads/
data/
output/

# 任务临时目录（与 settings 中 download_temp_subdir 等一致）
*_temp_playwright/
*.tmp
*.bak
*.corrupted
config.backup.json

# 数据库
*.db
*.sqlite
*.sqlite3

# 审计快照（本地调试生成）
*_screenshot.png
*_page.html
error_report*.md

# 前端（若后续引入）
node_modules/
npm-debug.log*
yarn-error.log*

# IDE / 系统
.idea/
.DS_Store
Thumbs.db
desktop.ini

# 本地打包备份
*.zip

# 证书与私钥
*.pem
*.key
*.crt
