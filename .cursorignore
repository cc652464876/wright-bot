# =============================================================================
# PrismPDF — Cursor AI 黑名单
# =============================================================================

# ---------------------------------------------------------------------------
# 浏览器内核二进制（体积极大，与业务无关）
# ---------------------------------------------------------------------------
chromium-1208/
chromium*/
.local-chromium/
.local-browsers/

# ---------------------------------------------------------------------------
# Python 运行时缓存
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
.ruff_cache/
.mypy_cache/
.pytest_cache/

# ---------------------------------------------------------------------------
# 虚拟环境（任意命名惯例均覆盖）
# ---------------------------------------------------------------------------
env/
venv/
.venv/
ENV/
.python-version

# ---------------------------------------------------------------------------
# Crawlee 与 Playwright 自动生成的存储目录
# ---------------------------------------------------------------------------
storage/
.crawlee/

# ---------------------------------------------------------------------------
# 日志文件
# ---------------------------------------------------------------------------
logs/
*.log
*.log.*

# ---------------------------------------------------------------------------
# 下载产物目录（爬虫输出，与源代码无关）
# ---------------------------------------------------------------------------
downloads/
data/
output/

# ---------------------------------------------------------------------------
# 数据库文件
# ---------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# ---------------------------------------------------------------------------
# 任务临时文件（爬虫运行时生成）
# ---------------------------------------------------------------------------
*_temp_playwright/
*.tmp
*.bak
*.corrupted
config.backup.json

# ---------------------------------------------------------------------------
# 错误快照（audit 子系统生成的截图和 HTML）
# ---------------------------------------------------------------------------
*_screenshot.png
*_page.html
error_report*.md

# ---------------------------------------------------------------------------
# 构建与打包产物
# ---------------------------------------------------------------------------
dist/
build/
*.egg-info/
wheels/

# ---------------------------------------------------------------------------
# Node.js（如果前端工具链存在）
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-error.log*

# ---------------------------------------------------------------------------
# 操作系统生成的杂项文件
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# 环境变量文件（含敏感密钥，绝对不能让 AI 读取）
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# 证书与密钥
# ---------------------------------------------------------------------------
*.pem
*.key
*.crt
